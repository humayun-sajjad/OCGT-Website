# ═══════════════════════════════════════════════
# OCGT — Security Headers, Compression & Caching
# ═══════════════════════════════════════════════

# Serve the SPA directly at the root URL (skip the legacy index.html meta-refresh)
DirectoryIndex OCGT_website.html index.html

# Force HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─────────────────────────────────────────────────────────────
# SPA path-based routing — internal rewrite of every clean URL
# (e.g. /geotechnik, /3d-vermessung) to OCGT_website.html so
# Google indexes each path as a distinct, crawlable URL.
# Does NOT rewrite real files (.css, .js, images, sitemap, etc.).
# ─────────────────────────────────────────────────────────────
RewriteCond %{REQUEST_URI} !^/OCGT_website\.html$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.(css|js|jpg|jpeg|png|gif|webp|svg|mp4|webm|woff2?|ttf|eot|ico|xml|txt|webmanifest|json|map)$
RewriteRule ^(.*)$ /OCGT_website.html [L]

# Redirect bare root and /index.html to clean root URL
RewriteRule ^index\.html$ / [R=301,L]

# Security Headers
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.bunny.net https://fonts.googleapis.com; font-src https://fonts.bunny.net https://fonts.gstatic.com data:; img-src 'self' data: blob:; frame-src https://cloud.pix4d.com; connect-src 'self' https://formspree.io; media-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self' https://formspree.io mailto:"
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
  ExpiresByType video/webm "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/octet-stream "access plus 1 year"
</IfModule>

# Prevent directory listing
Options -Indexes

# ────────────────────────────────────────────────
# Block access to sensitive / bulky / dev-only files
# ────────────────────────────────────────────────
# Raw scan data, source point clouds, uncompressed video masters
<FilesMatch "\.(las|laz|e57|ply|splat|npy|xyz|mov|mp4|m4v|avi|mkv|psd|ai|sketch|fig)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

# Content + config + binary data
<FilesMatch "\.(json|bin|log|md|docx|doc|xls|xlsx|txt|pdf|csv|tsv|gsr2|yml|yaml|toml|sql|db|sqlite)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

# Dotfiles, backup files, editor artifacts
<FilesMatch "(^\.|~$|\.bak$|\.swp$|\.orig$|\.tmp$|\.DS_Store$)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

# Dev-only artifacts (alternate build files, split-file experiments)
<FilesMatch "(BUILD-TOOL|split-index|ocgt-app\.js|ocgt-data\.js|ocgt-design-dark\.css|ocgt-design-light\.css|_sample_pcl)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

# Explicit allowlist: public web-delivered videos.
# Anything served by the site itself (hero loop, marketing clips) MUST be listed
# here, otherwise the global mp4/mov deny block above will return 403.
<FilesMatch "^(Hero_final-(1080|720)\.(mp4|webm)|Hero_final-poster\.jpg|Hero_glitch-(1080|720)\.(mp4|webm)|Hero_glitch-poster\.jpg|Hero-web(-compact)?\.(mp4|webm)|Website_hero-(1080|720)\.(mp4|webm)|signal-2021-12-25-17-04-33-257\.mp4)$">
  <IfModule mod_authz_core.c>
    Require all granted
  </IfModule>
</FilesMatch>

# Allow launch.json for local dev
<FilesMatch "launch\.json$">
  <IfModule mod_authz_core.c>
    Require all granted
  </IfModule>
</FilesMatch>

# Allow the site's key public files
<FilesMatch "^(robots\.txt|sitemap\.xml|manifest\.webmanifest|favicon\.ico|favicon\.svg|apple-touch-icon\.png|site\.webmanifest)$">
  <IfModule mod_authz_core.c>
    Require all granted
  </IfModule>
</FilesMatch>
